{
  "name": "moment-of-symmetry",
  "author": "Lumi Pakkanen",
  "version": "0.9.2",
  "type": "module",
  "description": "Moment of Symmetry (MOS) musical scale generation and analysis for Javascript",
  "license": "MIT",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/frostburn"
  },
  "main": "dist/src/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xenharmonic-devs/moment-of-symmetry.git"
  },
  "bugs": {
    "url": "https://github.com/xenharmonic-devs/moment-of-symmetry/issues"
  },
  "homepage": "https://github.com/xenharmonic-devs/moment-of-symmetry#readme",
  "keywords": [
    "Microtonal",
    "Music",
    "Xenharmonic",
    "MOS",
    "Moment of Symmetry",
    "Musical Scale",
    "Scale Generation",
    "Scale"
  ],
  "files": [
    "dist"
  ],
  "types": "dist/src/index.d.ts",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "gts": "^7.0.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "lint": "gts lint",
    "clean": "gts clean",
    "compile": "tsc",
    "fix": "gts fix",
    "prepare": "npm run compile",
    "pretest": "npm run compile",
    "posttest": "npm run lint",
    "test": "vitest",
    "doc": "typedoc src/index.ts --name moment-of-symmetry",
    "pretamnams-extension": "npm run compile",
    "tamnams-extension": "node dist/scripts/tamnams-extension.js",
    "bench": "vitest bench"
  },
  "dependencies": {
    "xen-dev-utils": "^0.13.0"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./core": {
      "types": "./dist/src/core.d.ts",
      "import": "./dist/src/core.js",
      "require": "./dist/src/core.js",
      "default": "./dist/src/core.js"
    },
    "./hardness": {
      "types": "./dist/src/hardness.d.ts",
      "import": "./dist/src/hardness.js",
      "require": "./dist/src/hardness.js",
      "default": "./dist/src/hardness.js"
    },
    "./names": {
      "types": "./dist/src/names.d.ts",
      "import": "./dist/src/names.js",
      "require": "./dist/src/names.js",
      "default": "./dist/src/names.js"
    },
    "./generator-ratio": {
      "types": "./dist/src/generator-ratio.d.ts",
      "import": "./dist/src/generator-ratio.js",
      "require": "./dist/src/generator-ratio.js",
      "default": "./dist/src/generator-ratio.js"
    },
    "./info": {
      "types": "./dist/src/info.d.ts",
      "import": "./dist/src/info.js",
      "require": "./dist/src/info.js",
      "default": "./dist/src/info.js"
    },
    "./notation": {
      "types": "./dist/src/notation.d.ts",
      "import": "./dist/src/notation.js",
      "require": "./dist/src/notation.js",
      "default": "./dist/src/notation.js"
    }
  }
}
