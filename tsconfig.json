{
  "extends": "./node_modules/gts/tsconfig-google.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": [
      "es2020"
    ],
    "target": "es2020",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "types": [
      "node"
    ]
  },
  "include": [
    "scripts/tamnams-extension.ts",
    "src/**/*.ts",
    "src/**/*.json"
  ],
  "exclude": [
    "src/__tests__/**",
    "src/__benchmarks__/**"
  ]
}
